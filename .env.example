# Google API Configuration
# 1. Create a Google Cloud project and enable the Drive API + Sheets API
# 2. Create an API key restricted by HTTP referrer (your domain)
# 3. Share your photos folder and videos spreadsheet with "Anyone with the link can view"

# Google API key — shared by the Drive gallery and the videos sheet
NEXT_PUBLIC_GOOGLE_API_KEY=

# Google Drive folder ID — from the URL: https://drive.google.com/drive/folders/{FOLDER_ID}
NEXT_PUBLIC_DRIVE_FOLDER_ID=

# Google Sheets spreadsheet ID — from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
# Sheet schema: Column A = video URL (YouTube or Instagram link), Column B = optional title
# The sheet must be shared "Anyone with the link can view"
NEXT_PUBLIC_VIDEOS_SHEET_ID=
