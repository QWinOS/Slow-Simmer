# Google API Configuration
# 1. Create a Google Cloud project and enable the Drive API + Sheets API
# 2. Create an API key restricted by HTTP referrer (your domain) — for Drive gallery
# 3. Create a service account — for private Sheets API access
# 4. Share your photos folder with "Anyone with the link can view"

# Google API key — for the Drive gallery (client-side)
NEXT_PUBLIC_GOOGLE_API_KEY=

# Google Drive folder ID — from the URL: https://drive.google.com/drive/folders/{FOLDER_ID}
NEXT_PUBLIC_DRIVE_FOLDER_ID=

# Google Sheets spreadsheet ID (server-only)
# Sheet schema: Column A = video URL (YouTube or Instagram link), Column B = optional title
VIDEOS_SHEET_ID=

# Google service account credentials (server-only)
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create a service account, enable Google Sheets API
# 3. Download the JSON key file
# 4. Share your videos spreadsheet with the service account email
# 5. Copy client_email and private_key here
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# RazorPay Configuration
# 1. Create account at razorpay.com
# 2. Get API keys from Dashboard → Settings → API Keys
# 3. Configure webhook at Dashboard → Settings → Webhooks → Add Webhook
#    URL: https://yourdomain.com/api/webhooks/razorpay
#    Events: payment.captured
#    Secret: set a secret and save as RAZORPAY_WEBHOOK_SECRET
#
# IMPORTANT: RAZORPAY_KEY_SECRET and RAZORPAY_WEBHOOK_SECRET are server-only env vars.
# They MUST NOT be prefixed with NEXT_PUBLIC_. Only NEXT_PUBLIC_RAZORPAY_KEY_ID may be
# exposed to the client bundle (it's the publishable key for the checkout modal).
RAZORPAY_KEY_ID=rzp_test_...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Brevo (Sendinblue) Email Configuration
# 1. Create account at brevo.com
# 2. Get API key from Dashboard → SMTP & API → API Keys
# 3. Verify sender email at Dashboard → Senders
#
# IMPORTANT: BREVO_API_KEY is server-only — NEVER prefix with NEXT_PUBLIC_.
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=hello@example.com
BREVO_SENDER_NAME=Slow Simmer
CONTACT_NUMBER=+91-XXXXXXXXXX
